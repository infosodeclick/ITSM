generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetStatus {
  IN_STOCK
  IN_USE
  REPAIR
  RETIRED
}

enum AssetType {
  NOTEBOOK
  DESKTOP
  MONITOR
  PRINTER
  NETWORK
  SERVER
  SOFTWARE
  OTHER
}

model Asset {
  id             String      @id @default(cuid())
  assetTag       String      @unique
  name           String
  type           AssetType   @default(OTHER)
  status         AssetStatus @default(IN_STOCK)
  serialNumber   String?
  manufacturer   String?
  model          String?
  assignedTo     String?
  location       String?
  purchaseDate   DateTime?
  warrantyUntil  DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status])
  @@index([type])
  @@index([assetTag])
}
