generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetStatus {
  IN_STOCK
  READY_TO_USE
  ASSIGNED
  IN_USE
  TRANSFERRED
  RETURNED
  REPAIR
  WAITING_REPAIR
  REPAIRING
  SPARE
  RETIRED
  PENDING_DISPOSAL
  DISPOSED
  LOST
}

enum AssetType {
  NOTEBOOK
  DESKTOP
  MONITOR
  PRINTER
  SCANNER
  MOBILE_PHONE
  TABLET
  NETWORK
  SERVER
  FIREWALL
  SWITCH
  ROUTER
  ACCESS_POINT
  CCTV
  UPS
  SOFTWARE
  MICROSOFT_365
  ADOBE_LICENSE
  ANTIVIRUS_EDR
  SAP_B1
  CRM
  EMAIL_ACCOUNT
  OTHER
}

enum AssetMovementType {
  ASSIGN
  TRANSFER
  RETURN
}

enum HrRequestType {
  ONBOARDING
  OFFBOARDING
}

enum HrRequestStatus {
  DRAFT
  SUBMITTED
  RECEIVED_BY_IT
  PREPARING
  WAITING_APPROVAL
  READY_TO_DELIVER
  DELIVERED
  COMPLETED
  CANCELLED
}

enum LicenseStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  CANCELLED
}

enum MaintenanceStatus {
  REPORTED
  CHECKING
  WAITING_VENDOR
  SENT_TO_REPAIR
  REPAIRED
  RETURNED
  CANNOT_REPAIR
  DISPOSED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationStatus {
  OPEN
  DONE
  DISMISSED
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  users           User[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  passwordHash  String?
  roleId        String?
  role          Role?      @relation(fields: [roleId], references: [id], onDelete: SetNull)
  isActive      Boolean    @default(true)
  createdAssets Asset[]    @relation("AssetCreatedBy")
  updatedAssets Asset[]    @relation("AssetUpdatedBy")
  auditLogs     AuditLog[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([roleId])
  @@index([isActive])
}

model Branch {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String?
  employees   Employee[]
  assets      Asset[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Department {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String?
  employees   Employee[]
  assets      Asset[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model AssetMovement {
  id              String            @id @default(cuid())
  type            AssetMovementType
  assetId         String?
  assetTag        String?
  assetName       String?
  fromHolder      String?
  toHolder        String?
  fromDepartment  String?
  toDepartment    String?
  fromBranch      String?
  toBranch        String?
  reason          String?
  conditionBefore String?
  conditionAfter  String?
  handledBy       String?
  approvedBy      String?
  movedAt         DateTime          @default(now())
  asset           Asset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([type])
  @@index([assetId])
  @@index([movedAt])
}

model HrRequest {
  id              String          @id @default(cuid())
  type            HrRequestType
  employeeCode    String?
  employeeName    String
  position        String?
  department      String?
  branch          String?
  managerName     String?
  employmentType  String?
  startDate       DateTime?
  lastWorkingDate DateTime?
  requestedItems  String?
  systemsNeeded   String?
  status          HrRequestStatus @default(SUBMITTED)
  owner           String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([type])
  @@index([status])
  @@index([startDate])
  @@index([lastWorkingDate])
}

model Employee {
  id             String      @id @default(cuid())
  employeeCode   String      @unique
  fullName       String
  email          String?
  position       String?
  departmentId   String?
  branchId       String?
  managerName    String?
  employmentType String?
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean     @default(true)
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  branch         Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assets         Asset[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([departmentId])
  @@index([branchId])
  @@index([isActive])
}

model AssetCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  prefix      String
  description String?
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vendor {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  notes       String?
  assets      Asset[]
  licenses    SoftwareLicense[]
  maintenance MaintenanceRecord[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SoftwareLicense {
  id           String        @id @default(cuid())
  name         String
  vendorId     String?
  vendorName   String?
  totalSeats   Int           @default(1)
  usedSeats    Int           @default(0)
  startDate    DateTime?
  expiryDate   DateTime?
  costPerSeat  Decimal?      @db.Decimal(12, 2)
  renewalCycle String?
  owner        String?
  department   String?
  branch       String?
  status       LicenseStatus @default(ACTIVE)
  notes        String?
  vendor       Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([expiryDate])
  @@index([vendorId])
}

model MaintenanceRecord {
  id         String            @id @default(cuid())
  assetId    String?
  assetTag   String?
  assetName  String?
  issue      String
  reportedBy String?
  handledBy  String?
  vendorId   String?
  vendorName String?
  cost       Decimal?          @db.Decimal(12, 2)
  status     MaintenanceStatus @default(REPORTED)
  reportedAt DateTime          @default(now())
  sentAt     DateTime?
  returnedAt DateTime?
  result     String?
  notes      String?
  asset      Asset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  vendor     Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([reportedAt])
}

model Budget {
  id         String   @id @default(cuid())
  fiscalYear Int
  category   String
  department String?
  branch     String?
  allocated  Decimal  @default(0) @db.Decimal(12, 2)
  actual     Decimal  @default(0) @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([fiscalYear])
  @@index([category])
}

model Approval {
  id        String         @id @default(cuid())
  module    String
  title     String
  amount    Decimal?       @db.Decimal(12, 2)
  requester String?
  approver  String?
  status    ApprovalStatus @default(PENDING)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([module])
  @@index([status])
}

model Notification {
  id        String             @id @default(cuid())
  module    String
  title     String
  message   String?
  dueDate   DateTime?
  status    NotificationStatus @default(OPEN)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([module])
  @@index([status])
  @@index([dueDate])
}

model Asset {
  id                String         @id @default(cuid())
  assetTag          String         @unique
  name              String
  type              AssetType      @default(OTHER)
  status            AssetStatus    @default(IN_STOCK)
  categoryId        String?
  currentEmployeeId String?
  departmentId      String?
  branchId          String?
  vendorId          String?
  serialNumber      String?
  manufacturer      String?
  model             String?
  spec              String?
  cpu               String?
  ram               String?
  storage           String?
  os                String?
  assignedTo        String?
  userPosition      String?
  location          String?
  purchaseDate      DateTime?
  purchasePrice     Decimal?       @db.Decimal(12, 2)
  invoiceNumber     String?
  warrantyStartDate DateTime?
  warrantyUntil     DateTime?
  condition         String?
  imageUrl          String?
  notes             String?
  createdById       String?
  updatedById       String?
  category          AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  currentEmployee   Employee?      @relation(fields: [currentEmployeeId], references: [id], onDelete: SetNull)
  department        Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  branch            Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  vendor            Vendor?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  movements         AssetMovement[]
  maintenance       MaintenanceRecord[]
  createdBy         User?          @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?          @relation("AssetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([status])
  @@index([type])
  @@index([assetTag])
  @@index([categoryId])
  @@index([currentEmployeeId])
  @@index([departmentId])
  @@index([branchId])
  @@index([vendorId])
  @@index([createdById])
  @@index([updatedById])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  module      String
  action      String
  entityType  String?
  entityId    String?
  beforeData  Json?
  afterData   Json?
  reason      String?
  ipAddress   String?
  userAgent   String?
  status      String   @default("SUCCESS")
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([module])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
